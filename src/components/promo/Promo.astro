---
import {Image} from 'astro:assets';
import {addNbsp} from '../../utility/Text';
import castle from '../../assets/promo/castle.png';
import CastleIco from '../../assets/promo/castle-ico.svg';
import TreeIco from '../../assets/promo/tree-ico.svg';
import CareIco from '../../assets/promo/care-ico.svg';

const promoItems = [
  {
    icon: CastleIco,
    title: 'HISTORICKÁ <br> PAMÁTKA',
    text: 'Renesanční sídlo s tradicí od 13. století.',
  },
  {
    icon: TreeIco,
    title: 'KRAJINA <br> A PŘÍRODA',
    text: 'Obklopeno krásnou středočeskou krajinou.',
  },
  {
    icon: CareIco,
    title: 'PEČUJEME <br> S ÚCTOU',
    text: 'S respektem k historii a místní komunitě.',
  }
];
---


<section aria-labelledby="promo-title" id="o-zamku">
    <div class="w-full">
        <div class="flex flex-col-reverse gap-8 sm:flex-row">

            <Image src={castle} alt="" width={600} height={400} class="hidden lg:flex object-cover max-w-full h-auto sm:max-w-[35%] sm:flex-[0_0_35%]"/>


            <div class="py-10 px-4 md:py-14">
                <div class="uppercase text-parchment-200 font-medium section-eyebrow" data-animate="fade-left"><p class="ml-8 sm:ml-14 tracking-wide text-sm md:text-base" data-animate="fade-left">Místo, kde se zastavil čas</p></div>
                <h2 class="text-ink-900 font-bold my-4 md:my-8" id="promo-title" data-animate="fade-left">{addNbsp('Historie. Příroda. Tradice.')}</h2>

                <p class="lg:text-xl md:max-w-[800px] my-4" data-animate="fade-left">{addNbsp('Zámek Zbenice se nachází ve stejnojmenné vesnici na jihu okresu Příbram ve Středočeském kraji. Na jeho místě původně stála starší středověká tvrz, kterou nechal v roce 1626 Vilém Šléglovský ze Šicendorfu přestavět na renesanční zámek, později upravený v barokním slohu. Zámecký areál se nachází v blízkosti rybníku na okraji vesnice Zbenice. Zámek je chráněn jako kulturní památka.')}</p>
                <p class="lg:text-xl md:max-w-[800px] my-4" data-animate="fade-left">{addNbsp('V roce 2007 byl zakoupen restaurátorem Jiřím Češkou, nyní slouží jako restaurátorská dílna. Také je využíván k příležitostným kulturním akcím.')}</p>

                <ul class="mt-8 md:mt-14 gap-6 md:gap-y-0 grid sm:grid-cols-2 md:grid-cols-3">
                    {promoItems.map((item, index) => {
                        const Icon = item.icon;

                        return (
                                <li style={`--transition-delay: ${index * 150}ms`} data-animate="fade-left">
                                <Icon class="animate fade-left"/>
                                <h3 class="animate fade-left font-semibold uppercase mt-3 mb-2" set:html={addNbsp(item.title)}></h3>
                                <p class="animate fade-left">{addNbsp(item.text)}</p>
                            </li>
                        );
                    })}
                </ul>
            </div>
        </div>
    </div>
</section>
