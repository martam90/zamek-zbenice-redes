---
import {siteTitle} from '../../config';
import Button from '../button/Button.astro';
import {addNbsp} from '../../utility/Text';
---


<div class="flex flex-col w-full max-w-[1190px] mx-auto px-4 py-10">
    <div class="uppercase text-parchment-200 font-medium section-eyebrow" data-animate="fade-left"><p class="ml-8 sm:ml-14 tracking-wide text-sm md:text-base" data-animate="fade-left">{addNbsp('Renesanční sídlo s příběhem')}</p></div>
    <h1 class="relative z-1 text-ink-900 font-bold my-4 max-w-md" data-animate="fade-left">{addNbsp(siteTitle)}</h1>
    <p class="relative z-1 md:text-xl max-w-[400px]" data-animate="fade-left">{addNbsp('Historické sídlo v srdci středních Čech, kde se setkává renesanční architektura s klidem přírody. Objevte místo s tradicí sahající až do roku 1293.')}</p>

    <div class="mt-8 flex flex-wrap gap-4" data-animate="fade-left">
    <Button title={'O zámku'} href={'/#o-zamku'} variant={'primary'}/>

    <Button title={'Prohlédnout galerii'} href={'/#galerie'} variant={'secondary'} />
</div>